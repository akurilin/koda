# Copy this file to `web/.env.local` and fill in the required values.
#
# Next.js loads `.env.local` automatically for `next dev` and `next start`,
# and it's gitignored at the repo root so real keys never ship. Only
# `ANTHROPIC_API_KEY` is strictly required — the rest have sensible
# defaults tuned for the local Supabase stack started via
# `npx supabase start` from the repository root.

# ─── Required ────────────────────────────────────────────────────────────────

# Your Anthropic API key. Used by `app/api/chat/route.ts` to drive the
# editorial assistant. The editor UI still loads without it, but any chat
# request will 500 until this is set. Mint a key at
# https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────────────────────────────────────

# Anthropic model ID to use for the assistant. Defaults to
# `claude-sonnet-4-5` when unset. Override to try Opus for tougher edits
# or Haiku for faster/cheaper iterations.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Postgres connection string. Defaults to the local Supabase stack
# (`npx supabase start`) at port 54322. Only override this if you're
# pointing the app at a non-default Postgres — e.g. a hosted Supabase
# project, or a second local cluster for experiments.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Max concurrent Postgres connections for the shared `postgres.js` client.
# Defaults to 5, which is comfortable for local dev. Raise if you're
# running many parallel integration tests against a beefier database.
# DATABASE_MAX_CONNECTIONS=5

# ─── Test-only ───────────────────────────────────────────────────────────────

# Set to `true` to opt into the Playwright spec that exercises a real
# Anthropic round-trip (`tests/e2e/agent-edit.spec.ts`). Otherwise the
# spec is skipped, which is the default in CI so we don't spend Anthropic
# credits on every push. Requires ANTHROPIC_API_KEY to also be set.
# RUN_AGENT_QA=true

# Override the directory Playwright writes traces / screenshots / reports
# to. Defaults to `/tmp/koda/playwright`. Only worth setting if `/tmp` is
# tight on space or you want artifacts preserved somewhere persistent.
# KODA_QA_ARTIFACTS_DIR=/tmp/koda/playwright
